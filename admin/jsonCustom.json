    "items": {
        "title": {
            "newLine": true,
            "type": "text",
            "label": "Title",
            "help": "Title template (optional)",
            "default": "",
            "xs": 12,
            "sm": 6
        },
        "message": {
            "type": "text",
            "label": "Message",
            "help": "Message template",
            "hidden": "customObj.common.type === 'boolean'",
            "default": "",
            "xs": 12,
            "sm": 6
        },
        "priority": {
            "newLine": true,
            "type": "select",
            "label": "Priority",
            "default": "normal",
            "options": [
                { "value": "normal", "label": "Normal" },
                { "value": "high", "label": "High" }
            ],
            "xs": 12,
            "sm": 6
        },
        "expire": {
            "type": "number",
            "label": "Expire (seconds)",
            "help": "0 = no expiry",
            "default": 0,
            "min": 0,
            "max": 172800,
            "xs": 12,
            "sm": 6
        },
        "reportChanges": {
            "newLine": true,
            "type": "checkbox",
            "label": "Report changes only",
            "help": "Sends a new message if the value changes",
            "default": true,
            "xs": 12,
            "sm": 6
        },
        "debounceDifference": {
            "type": "number",
            "label": "Debounce difference",
            "help": "Minimal change before next notification",
            "hidden": "customObj.common.type === 'boolean'",
            "default": 0,
            "min": 0,
            "xs": 12,
            "sm": 6
        },
        "offStatus": {
            "newLine": true,
            "hidden": "customObj.common.type !== 'boolean' || data.onlyTrue",
            "hideOnlyControl": true,
            "type": "text",
            "label": "OFF status",
            "help": "Default - 'OFF'",
            "default": "",
            "xs": 12,
            "sm": 6
        },
        "onStatus": {
            "type": "text",
            "hidden": "customObj.common.type !== 'boolean' || data.onlyFalse",
            "label": "ON status",
            "help": "Default - 'ON'",
            "default": "",
            "xs": 12,
            "sm": 6
        },
        "onlyFalse": {
            "newLine": true,
            "type": "checkbox",
            "hidden": "customObj.common.type !== 'boolean'",
            "disabled": "data.onlyTrue",
            "label": "Only false",
            "help": "Do not show ON",
            "default": false,
            "xs": 12,
            "sm": 6
        },
        "onlyTrue": {
            "hidden": "customObj.common.type !== 'boolean'",
            "disabled": "data.onlyFalse",
            "defaultFunc": "customObj.common ? !!(customObj.common.role || '').match(/^button/) : false",
            "type": "checkbox",
            "label": "Only true",
            "help": "Do not show OFF",
            "xs": 12,
            "sm": 6
        },
        "devices": {
            "type": "text",
            "label": "Devices",
            "help": "Comma-separated device IDs (empty = all)",
            "default": "",
            "xs": 12,
            "sm": 12
        }
    }
}
